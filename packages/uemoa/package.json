{
  "name": "@bemedev/accounting-uemoa",
  "version": "0.2.0",
  "description": "SYSCOHADA / UEMOA Chart of Accounts",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "files": [
    "lib"
  ],
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/accounting"
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "UEMOA",
    "accounting",
    "currency",
    "accounting system"
  ],
  "scripts": {
    "build": "pnpm run rm:lib && pnpm run rolldown",
    "rm:lib": "pnpx rimraf ./lib",
    "test": "vitest run",
    "fmt": "oxfmt",
    "lint": "oxlint --fix && pnpm run fmt",
    "pretest": "pnpm run build && pnpm run size",
    "posttest": "exit 0",
    "test:only": "pnpm run test --no-coverage",
    "_ci": "pnpm run lint && pnpm run test",
    "size": "size-limit",
    "rolldown": "rolldown -c"
  },
  "devDependencies": {
    "@bemedev/dev-utils": "^0.8.3",
    "@bemedev/shared-vitest": "workspace:^",
    "rolldown": "^1.1.3",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "size-limit": [
    {
      "path": "lib/**/*.js",
      "limit": "50 kb"
    },
    {
      "path": "lib/**/*.d.ts",
      "limit": "100 kb"
    },
    {
      "path": "lib/**/*.cjs",
      "limit": "50 kb"
    }
  ]
}
