{
  "name": "@bemedev/uemoa-viewer",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "description": "SYSCOHADA/UEMOA Chart of Accounts viewer — SolidJS + TanStack",
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/accounting"
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "_preconfig": "chmod +x .husky/commit-msg && chmod +x .husky/pre-commit",
    "build": "vite build",
    "prebuild": "pnpm --filter @bemedev/accounting-uemoa --filter @bemedev/tansolid build",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && pnpm run p-q && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade && pnpm run ci",
    "dev": "vite dev",
    "dev:host": "pnpm run dev --host",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test:coverage": "vitest run",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:fix": "oxlint --fix",
    "lint:watch": "onchange --await-write-finish 5500 -d 50000 -v \"**/*.ts\" -- pnpm run lint",
    "prepare": "husky",
    "pretest": "pnpm run build",
    "preview": "pnpm run build && vite start",
    "p-q": "pretty-quick",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "start": "vite start",
    "test": "pnpm run test:coverage --no-coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm up --latest"
  },
  "bundleDependencies": [
    "@bemedev/tansolid"
  ],
  "dependencies": {
    "@bemedev/accounting-uemoa": "workspace:^",
    "@bemedev/app": "^1.4.0",
    "@bemedev/app-solidjs": "^1.4.0",
    "@bemedev/decompose": "^2.2.0",
    "@bemedev/fsf": "^1.0.1",
    "@bemedev/i18n": "^0.7.0",
    "@bemedev/pipe": "^1.6.1",
    "@bemedev/sleep": "^0.2.2",
    "@kobalte/core": "^0.13.11",
    "@solid-primitives/intersection-observer": "^2.2.4",
    "@solid-primitives/storage": "^4.3.4",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/pacer-lite": "^0.2.2",
    "@tanstack/solid-hotkeys": "^0.10.0",
    "@tanstack/solid-pacer": "^0.21.1",
    "@tanstack/solid-router": "1.170.16",
    "@tanstack/solid-start": "1.168.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "lucide-solid": "^1.21.0",
    "nitro": "3.0.260610-beta",
    "redaxios": "^0.5.1",
    "solid-js": "^1.9.13",
    "solid-motionone": "^1.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.4.1",
    "vinxi": "0.5.11",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@bemedev/dev-utils": "^0.8.3",
    "@bemedev/tansolid": "workspace:^",
    "@bemedev/vitest-alias": "^0.0.3",
    "@content-collections/core": "^0.15.2",
    "@content-collections/markdown": "^0.1.4",
    "@content-collections/vite": "^0.3.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tanstack/solid-router-devtools": "1.167.0",
    "@toolwind/corner-shape": "0.0.8-3",
    "@types/clone-deep": "^4.0.4",
    "@types/node": "^26.0.1",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "combinate": "^1.1.11",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-plugin-solid": "^2.11.12",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.9"
  }
}
